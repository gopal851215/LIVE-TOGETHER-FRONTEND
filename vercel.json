{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "outputDirectory": "dist",
  "framework": "vite",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/api/(.*)",
"destination": "https://live-together-backend-2.onrender.com/api/$1"
    },
    {
      "source": "/uploads/(.*)",
"destination": "https://live-together-backend-2.onrender.com/uploads/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
